# API Keys for LLM Services
# Copy this file to .env and fill in your actual API keys

# OpenAI API Key (required for some evaluations)
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Key (for fast inference)
GROQ_API_KEY=your_groq_api_key_here

# Together AI API Key
TOGETHER_API_KEY=your_together_api_key_here

# Llama API Key (if using Llama cloud services)
LLAMA_API_KEY=your_llama_api_key_here

# Refusal Evaluation Method
# Options: LLAMA, GROQ, TOGETHER, VLLM
# VLLM: Requires running local vLLM server (see instructions below)
REFUSAL_EVAL_METHOD=GROQ

# Intrinsic Hallucination Evaluation Model
# Options: llama-3.3-70b-versatile (Groq), Llama-3.3-70B-Instruct
INTRINSIC_HALLUCINATION_MODEL=llama-3.3-70b-versatile

# VLLM Configuration (if using REFUSAL_EVAL_METHOD=VLLM):
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=dummy

# VLLM Instructions:
# If running refusal evaluation with VLLM, please ensure you ran:
# HF_TOKEN=xxx vllm serve meta-llama/Llama-Guard-4-12B --port 8000 --max-model-len 10000
# on a GPU via vLLM. In the paper it was run with vLLM 0.9.0 and "transformers<4.54.0"